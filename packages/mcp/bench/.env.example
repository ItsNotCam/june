# june-eval required environment variables (§29.1).
#
# Hard-fail at startup if any required var is unset. Mirrors the mcp
# pattern — no silent defaults for deployment-coupled secrets.

# --- required ---

# Anthropic API key. Used by the judge (always Anthropic Batch API) and
# by role 1 / reader when those roles are configured for anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# Ollama server endpoint. Used by the reader (when ollama) and by the
# Tier-2 ground-truth resolver (always — it mirrors june's embedder).
OLLAMA_URL=http://localhost:11434

# Qdrant server endpoint. Must point at a bench-dedicated instance —
# never the operator's real Qdrant. `health` will refuse a URL it
# hasn't been confirmed against on first run.
QDRANT_URL=http://localhost:6334

# Path or command name for june's CLI. The bench shells out to
# `${JUNE_BIN} ingest <corpus>` during Stage 4.
JUNE_BIN=june

# Config YAML path. Discovery order: --config > this > ./config.yaml > defaults.
CONFIG_PATH=./config.yaml

# --- optional ---

# OpenAI API key. Required only when any role is configured for openai.
# Role 2 (query author) defaults to openai.
# OPENAI_API_KEY=sk-...

# Qdrant auth token for deployed clusters.
# QDRANT_API_KEY=

# Log level override (winston npm levels: error | warn | info | http | verbose | debug | silly).
# LOG_LEVEL=info

# Scratch root override — per-run isolated scratch directories live here.
# Defaults to config.ingest.scratch_root (./bench-scratch).
# BENCH_SCRATCH_ROOT=/tmp/bench
