# june ingestion-pipeline required environment (§29.1 / I13).
#
# Hard-fail at startup if any of these are unset. No silent defaults —
# a wrong model name is a deployment error, surfaced loudly.

# Ollama server endpoint. Supports localhost, LAN, or a dedicated private host.
OLLAMA_URL=http://localhost:11434

# Qdrant server endpoint.
QDRANT_URL=http://localhost:6333

# Optional: Qdrant API key for authenticated deployments.
# QDRANT_API_KEY=

# Embedding / classifier / summarizer model names. Must be pulled on the Ollama host.
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CLASSIFIER_MODEL=llama3.2:3b
OLLAMA_SUMMARIZER_MODEL=llama3.2:3b

# Config YAML path. Default discovery: --config flag > this > ./config.yaml
# > ~/.config/june/config.yaml > shipped defaults.
CONFIG_PATH=./config.yaml

# Optional: log level override (debug | info | warn | error).
# LOG_LEVEL=info
