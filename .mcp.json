{
  "mcpServers": {
    "june-mcp": {
      "type": "stdio",
      "command": "bun",
      "args": ["run", "/app/packages/mcp/src/index.ts"],
      "cwd": "/app",
      "env": {
        "QDRANT_URL": "http://localhost:6333",
        "OLLAMA_URL": "http://localhost:11434",
        "CONFIG_PATH": "/app/packages/mcp/config.yaml"
      }
    }
  }
}
